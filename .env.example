# =========================================================
# ChemIP Platform - Environment Template
# =========================================================

# -----------------------------
# Public Data API Keys (data.go.kr)
# -----------------------------
KOSHA_SERVICE_KEY_ENCODED=YOUR_ENCODED_KOSHA_KEY
KOSHA_SERVICE_KEY_DECODED=YOUR_DECODED_KOSHA_KEY

KOTRA_API_KEY_ENCODED=YOUR_ENCODED_KOTRA_KEY
KOTRA_API_KEY_DECODED=YOUR_DECODED_KOTRA_KEY

DRUG_API_KEY_ENCODED=YOUR_ENCODED_DRUG_KEY
DRUG_API_KEY_DECODED=YOUR_DECODED_DRUG_KEY

# Tourism key (optional: if different from KOTRA key)
TOURISM_API_KEY_DECODED=YOUR_TOURISM_KEY_IF_DIFFERENT

# -----------------------------
# KIPRIS
# -----------------------------
KIPRIS_API_KEY=YOUR_KIPRIS_KEY

# -----------------------------
# PubMed (optional)
# -----------------------------
PUBMED_API_KEY=YOUR_PUBMED_API_KEY

# -----------------------------
# Naver News API (optional fallback)
# -----------------------------
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET

# -----------------------------
# EPA CompTox (optional — US toxicity data)
# -----------------------------
COMPTOX_API_KEY=YOUR_COMPTOX_API_KEY

# -----------------------------
# Localhost port allocation (Track 3 - ChemIP)
# -----------------------------
FRONTEND_PORT=7000
BACKEND_PORT=7010
BACKEND_ORIGIN=http://127.0.0.1:7010

# -----------------------------
# Endpoint overrides (optional)
# -----------------------------
KOTRA_MARKET_NEWS_URL=https://apis.data.go.kr/B410001/kotra_overseasMarketNews/ovseaMrktNews/ovseaMrktNews
KOTRA_ENTRY_STRATEGY_URL=https://apis.data.go.kr/B410001/entryStrategy/entryStrategy
KOTRA_PRICE_INFO_URL=https://apis.data.go.kr/B410001/priceInfoByNatn/priceInfoByNatn
KOTRA_FRAUD_CASE_URL=https://apis.data.go.kr/B410001/cmmrcFraudCase/cmmrcFraudCase
KOTRA_NATIONAL_INFO_URL=https://apis.data.go.kr/B410001/kotra_nationalInformation/natnInfo/natnInfo
KOTRA_ENTERPRISE_SUCCESS_URL=https://apis.data.go.kr/B410001/compSucsCase/compSucsCase
KOTRA_IMPORT_RESTRICTION_URL=https://apis.data.go.kr/B410001/DS00000128/getDS00000128

TOURISM_KOREAN_URL=https://apis.data.go.kr/B551011/KorPetTourService2/areaBasedList2
TOURISM_ENGLISH_URL=https://apis.data.go.kr/B551011/EngService2/searchFestival2

# -----------------------------
# Path standardization (Design-first)
# -----------------------------
# Relative paths are recommended as defaults.
TERMINOLOGY_DB_PATH=./data/terminology.db
GLOBAL_PATENT_INDEX_DB_PATH=./data/global_patent_index.db
USPTO_INDEX_DB_PATH=./data/uspto_index.db
KOSHA_GUIDE_DATA_DIR=./data/kosha_guide

# -----------------------------
# Runtime stability defaults
# -----------------------------
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=0.5
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# -----------------------------
# Local LLM (Ollama)
# -----------------------------
LLM_ENABLED=true
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:4b
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# -----------------------------
# Logging / CORS
# -----------------------------
LOG_DIR=./logs
LOG_LEVEL_FILE=DEBUG
LOG_LEVEL_CONSOLE=ERROR

CORS_ORIGINS=*
